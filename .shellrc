#

myshell=bash
if [ -n "$ZSH_VERSION" ] ; then
  myshell=zsh
fi

function SOURCE() {
  [ -f "$1" ] && source "$1"
}

function ADD_PATH() {
  [ -d "$1" ] && export PATH="$PATH:$1"
}

SOURCE ~/.zsh_aliases
SOURCE ~/.bash_aliases

#export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'
export WINEARCH=win32
export WINEPREFIX=/home/lordy/.wine32
# --- nvm -------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"                  # loads nvm
[ -s "$NVM_DIR/${myshell}_completion" ] && \. "$NVM_DIR/${myshell}_completion"  # loads nvm completion (needs bashcompinit above)
export PATH="/home/lordy/.assemblyai-cli:$PATH"

# --- Google Cloud SDK ------------------------------------------------------
# zsh variants of the SDK include files (must come after compinit).
SOURCE '/home/lordy/google-cloud-sdk/path.$myshell.inc'
SOURCE '/home/lordy/google-cloud-sdk/completion.$myshell.inc'

export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - $myshell)"
eval "$(pyenv virtualenv-init -)"

SOURCE ~/.fzf.$myshell

ADD_PATH ~/bin
ADD_PATH ~/.local/bin

export USE_BUILTIN_RIPGREP=0

echo loaded $myshell
